{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@db/*": [
        "./lib/db/src/*"
      ],
      "@workspace/db": [
        "./lib/db/src/index.ts"
      ],
      "@workspace/api-zod": [
        "./lib/api-zod/src/index.ts"
      ],
      "@workspace/api-client-react": [
        "./lib/api-client-react/src/index.ts"
      ]
    },
    "jsx": "preserve",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": [
      "vite/client",
      "node"
    ],
    "allowJs": true,
    "strict": false,
    "incremental": true,
    "esModuleInterop": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app",
    "lib",
    "src",
    ".next/types/**/*.ts"
  ],
  "references": [
    {
      "path": "./lib/db"
    },
    {
      "path": "./lib/api-client-react"
    },
    {
      "path": "./lib/api-zod"
    }
  ],
  "exclude": [
    "node_modules"
  ]
}
